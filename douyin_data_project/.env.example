# Environment variables for Douyin Data Project
# Copy this file to .env and fill in your actual values

# Project settings
PROJECT_ENV=development  # development, testing, production
DATA_VERSION=v0.1

# Web crawler settings (optional)
CRAWLER_DELAY=1.5
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# API settings (required for API module, placeholder for now)
DOUYIN_CLIENT_ID=your_client_id_here
DOUYIN_CLIENT_SECRET=your_client_secret_here
DOUYIN_REDIRECT_URI=https://your-app.com/callback
DOUYIN_ACCESS_TOKEN=your_access_token_here
DOUYIN_REFRESH_TOKEN=your_refresh_token_here
DOUYIN_OPEN_ID=your_open_id_here

# Logging settings
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Data paths (relative to project root)
DATA_DIR=./data
LOG_DIR=./logs

# Processing settings
ENGAGEMENT_LIKE_WEIGHT=1.0
ENGAGEMENT_COMMENT_WEIGHT=2.0
ENGAGEMENT_SHARE_WEIGHT=3.0

# Feature flags
USE_MOCK_DATA=true
ENABLE_API=false